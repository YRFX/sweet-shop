.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 46px;
  background: #f7f5f2;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -1px 6px rgba(0,0,0,0.05);
  z-index: 999;
}
.item {
  display: flex;
  align-items: center;
  justify-content: center;
}
text {
  font-size: 13px;
  color: #999;
}
text.active {
  color: #ff8a80;
  font-weight: 500;
}